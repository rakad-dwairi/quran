{
  "expo": {
    "scheme": "quran",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "name": "Quran",
    "slug": "quran",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to show accurate prayer times near you."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    }
  }
}
